# hyperpanes-mcp environment variables (all optional). Set them in the MCP
# server's `env` block (e.g. in claude config), not a loaded .env — this server
# reads process.env directly.

# --- launch_workspace (Phase 1) ---------------------------------------------
# Path to the hyperpanes executable. Required only for launch_workspace; there
# is no PATH fallback. e.g. C:\path\to\hyperpanes.exe
HYPERPANES_BIN=
# Whitespace-separated leading args for the launcher (e.g. a dev runner).
HYPERPANES_LAUNCH_ARGS=

# --- control API discovery (Phase 2) ----------------------------------------
# Override the path to the app's control.json. Use this if the app runs under a
# non-default Electron data dir (control_status prints the path it tried).
HYPERPANES_CONTROL_FILE=
# Or override just the userData dir: <dir>/control.json is used.
HYPERPANES_USER_DATA=
# A scoped control token + port handed to a child pane (used instead of reading
# control.json). Set automatically by mint_token/open_pane for child panes.
HYPERPANES_CONTROL_TOKEN=
HYPERPANES_CONTROL_PORT=
# The pane id this bridge runs inside (enables whoami / self-identification).
HYPERPANES_PANE_ID=

# --- send_input safety gate (Phase 2) ---------------------------------------
# send_input is OFF unless this is set to 1/true (and the app's "Allow agent
# control -> input" toggle is on, and every call passes confirm:true).
HYPERPANES_ALLOW_INPUT=
# Optional comma-separated pane ids or labels that may receive input.
HYPERPANES_INPUT_ALLOWLIST=
